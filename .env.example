# Plex Configuration
PLEX_URL=http://192.168.1.100:32400
PLEX_TOKEN=your_plex_token_here
PLEX_LIBRARY_NAME=TV Shows

# NFS Configuration (if using NFS mount)
NFS_MOUNT_OPTIONS=addr=10.10.10.2,vers=4,soft,timeo=180,retrans=2,noresvport
NFS_DEVICE=:/path/to/tvshows

# Local Configuration (for reference in Dockerfile/docker-compose)
TV_SHOWS_PATH=/tv

# Logging
VERBOSE=false
VERBOSE_MATCHING=false

# Features
OVERWRITE=false
